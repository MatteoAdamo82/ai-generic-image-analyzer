# Configurazione del servizio generico di analisi immagini

# Server
HOST=0.0.0.0
PORT=8002
DEBUG=false

# Sicurezza (opzionale)
API_KEY=image-analyzer-api-key
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Limiti immagini
MAX_IMAGE_SIZE_MB=10
MIN_IMAGE_WIDTH=32
MIN_IMAGE_HEIGHT=32
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096

# Formati supportati (separati da virgola)
SUPPORTED_FORMATS=jpg,jpeg,png,webp,gif,bmp

# Performance
ANALYSIS_TIMEOUT=60
MAX_CONCURRENT_REQUESTS=5

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Note:
# - Questo servizio è completamente disaccoppiato
# - Le configurazioni AI (provider, api_key, model) vengono passate nella richiesta
# - Non ci sono dipendenze da altre applicazioni
# - Può essere utilizzato da qualsiasi applicazione o piattaforma