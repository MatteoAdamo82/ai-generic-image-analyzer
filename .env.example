# Configurazione del servizio generico di analisi immagini

# Server
HOST=0.0.0.0
PORT=8002
DEBUG=false

# Sicurezza — JWT inter-servizio (machine-to-machine)
# Deve corrispondere a IMAGE_ANALYZER_SERVICE_JWT_SECRET nel .env di whatsagent
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
# Se non impostato l'autenticazione è DISABILITATA (solo per sviluppo!)
SERVICE_JWT_SECRET=change-this-to-a-strong-random-secret-in-production
ALLOWED_ORIGINS=*
OLLAMA_MODEL=llava:13b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Limiti immagini
MAX_IMAGE_SIZE_MB=10
MIN_IMAGE_WIDTH=32
MIN_IMAGE_HEIGHT=32
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096

# Formati supportati (separati da virgola)
SUPPORTED_FORMATS=jpg,jpeg,png,webp,gif,bmp

# Performance
ANALYSIS_TIMEOUT=60
MAX_CONCURRENT_REQUESTS=5

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Note:
# - Questo servizio è completamente disaccoppiato
# - Le configurazioni AI (provider, api_key, model) vengono passate nella richiesta
# - Non ci sono dipendenze da altre applicazioni
# - Può essere utilizzato da qualsiasi applicazione o piattaforma
